#!/usr/bin/env bash
# Stub tmux for tests. Logs argv; answers list/has/display from env.
# FAKE_TMUX_LOG       — append each invocation as one line of "$*"
# FAKE_TMUX_SESSIONS  — newline-separated session names
# FAKE_TMUX_META      — lines "name|window|meta" for display-message
#                       meta ≈ "2w attached claude" or "1w detached bash"
# FAKE_TMUX_WINDOWS   — lines "session:idx:name" for list-windows / window_index
set -u

logf="${FAKE_TMUX_LOG:-}"
if [[ -n "$logf" ]]; then
  printf '%s\n' "$*" >>"$logf"
fi

cmd="${1:-}"
shift || true

_lookup_meta() {
  # sets: _win _meta _wins _attword _cmd
  local name="$1" line mname rest
  _win="bash"
  _meta="1w detached bash"
  _wins="1"
  _attword="detached"
  _cmd="bash"
  [[ -z "${FAKE_TMUX_META:-}" ]] && return 0
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    mname="${line%%|*}"
    rest="${line#*|}"
    if [[ "$mname" == "$name" ]]; then
      _win="${rest%%|*}"
      _meta="${rest#*|}"
      # parse "Nw attached|detached rest..."
      if [[ "$_meta" =~ ^([0-9]+)w[[:space:]]+(attached|detached)[[:space:]]*(.*)$ ]]; then
        _wins="${BASH_REMATCH[1]}"
        _attword="${BASH_REMATCH[2]}"
        _cmd="${BASH_REMATCH[3]:-bash}"
      fi
      return 0
    fi
  done <<< "$FAKE_TMUX_META"
}

# Active window index for session: match active name in FAKE_TMUX_WINDOWS, else 0.
_active_window_index() {
  local name="$1" line sess idx wname rest
  _lookup_meta "$name"
  if [[ -n "${FAKE_TMUX_WINDOWS:-}" ]]; then
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      sess="${line%%:*}"
      rest="${line#*:}"
      idx="${rest%%:*}"
      wname="${rest#*:}"
      if [[ "$sess" == "$name" && "$wname" == "$_win" ]]; then
        printf '%s\n' "$idx"
        return 0
      fi
    done <<< "$FAKE_TMUX_WINDOWS"
  fi
  printf '0\n'
}

case "$cmd" in
  list-sessions)
    if [[ -n "${FAKE_TMUX_SESSIONS:-}" ]]; then
      printf '%s\n' "$FAKE_TMUX_SESSIONS"
    fi
    exit 0
    ;;
  list-windows)
    target=""
    line=""; sess=""; idx=""; wname=""; rest=""; name=""
    while (( $# )); do
      case "$1" in
        -t) target="${2:-}"; shift 2 ;;
        -F) shift 2 ;;
        -*) shift ;;
        *) shift ;;
      esac
    done
    name="${target#=}"
    if [[ -n "${FAKE_TMUX_WINDOWS:-}" ]]; then
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        sess="${line%%:*}"
        rest="${line#*:}"
        idx="${rest%%:*}"
        wname="${rest#*:}"
        [[ "$sess" == "$name" ]] || continue
        # Always emit index:name (matches -F '#{window_index}:#{window_name}')
        printf '%s:%s\n' "$idx" "$wname"
      done <<< "$FAKE_TMUX_WINDOWS"
    else
      # Fall back to single active window from meta (index 0).
      _lookup_meta "$name"
      printf '%s:%s\n' "0" "$_win"
    fi
    exit 0
    ;;
  has-session)
    target=""
    while (( $# )); do
      case "$1" in
        -t) target="${2:-}"; shift 2 ;;
        *) shift ;;
      esac
    done
    name="${target#=}"
    if [[ -z "$name" || -z "${FAKE_TMUX_SESSIONS:-}" ]]; then
      exit 1
    fi
    while IFS= read -r s; do
      [[ "$s" == "$name" ]] && exit 0
    done <<< "$FAKE_TMUX_SESSIONS"
    exit 1
    ;;
  display-message)
    target=""; format=""
    while (( $# )); do
      case "$1" in
        -p) shift ;;
        -t) target="${2:-}"; shift 2 ;;
        -*) shift ;;
        *) format="$1"; shift ;;
      esac
    done
    name="${target#=}"
    # target may be session:window for capture-pane-like targets; strip window
    if [[ "$name" == *:* ]]; then
      name="${name%%:*}"
    fi
    _lookup_meta "$name"

    case "$format" in
      *'#{window_name}'*)
        # bare window name (not a multi-field format)
        if [[ "$format" != *'#{session_'* && "$format" != *'#{pane_'* && "$format" != *'#{window_index}'* ]]; then
          printf '%s\n' "$_win"
        else
          printf '%s\n' "$_meta"
        fi
        ;;
      *'#{window_index}'*)
        _active_window_index "$name"
        ;;
      *'#{session_windows}'*)
        if [[ "$format" == *'#{?session_attached'* || "$format" == *'#{pane_'* ]]; then
          printf '%s\n' "$_meta"
        else
          printf '%s\n' "$_wins"
        fi
        ;;
      *'#{session_attached}'*)
        if [[ "$_attword" == "detached" ]]; then
          printf '0\n'
        else
          printf '1\n'
        fi
        ;;
      *'#{pane_current_command}'*)
        printf '%s\n' "$_cmd"
        ;;
      *)
        printf '%s\n' "$_meta"
        ;;
    esac
    exit 0
    ;;
  show-options)
    # No claim markers → always empty (claimable)
    exit 0
    ;;
  attach|new-session|set-option|send-keys|new|kill-session|rename-session|capture-pane)
    exit 0
    ;;
  *)
    exit 0
    ;;
esac
