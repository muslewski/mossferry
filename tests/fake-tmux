#!/usr/bin/env bash
# Stub tmux for tests. Logs argv; answers list/has/display from env.
# FAKE_TMUX_LOG       — append each invocation as one line of "$*"
# FAKE_TMUX_SESSIONS  — newline-separated session names
# FAKE_TMUX_META      — lines "name|window|meta" for display-message
set -u

logf="${FAKE_TMUX_LOG:-}"
if [[ -n "$logf" ]]; then
  printf '%s\n' "$*" >>"$logf"
fi

cmd="${1:-}"
shift || true

case "$cmd" in
  list-sessions)
    # Print session names (ignore -F / other flags). Empty env → no output.
    if [[ -n "${FAKE_TMUX_SESSIONS:-}" ]]; then
      printf '%s\n' "$FAKE_TMUX_SESSIONS"
    fi
    exit 0
    ;;
  has-session)
    target=""
    while (( $# )); do
      case "$1" in
        -t) target="${2:-}"; shift 2 ;;
        *) shift ;;
      esac
    done
    name="${target#=}"
    if [[ -z "$name" || -z "${FAKE_TMUX_SESSIONS:-}" ]]; then
      exit 1
    fi
    while IFS= read -r s; do
      [[ "$s" == "$name" ]] && exit 0
    done <<< "$FAKE_TMUX_SESSIONS"
    exit 1
    ;;
  display-message)
    target=""; format=""
    while (( $# )); do
      case "$1" in
        -p) shift ;;
        -t) target="${2:-}"; shift 2 ;;
        -*) shift ;;
        *) format="$1"; shift ;;
      esac
    done
    name="${target#=}"
    window=""; meta=""
    if [[ -n "${FAKE_TMUX_META:-}" ]]; then
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        mname="${line%%|*}"
        rest="${line#*|}"
        mwin="${rest%%|*}"
        mmeta="${rest#*|}"
        if [[ "$mname" == "$name" ]]; then
          window="$mwin"
          meta="$mmeta"
          break
        fi
      done <<< "$FAKE_TMUX_META"
    fi
    # Defaults when no META row
    [[ -n "$window" ]] || window="bash"
    [[ -n "$meta" ]] || meta="1w detached bash"

    if [[ "$format" == *'#{window_name}'* && "$format" != *'#{session_'* && "$format" != *'#{pane_'* ]]; then
      printf '%s\n' "$window"
    elif [[ "$format" == *'#{session_attached}'* && "$format" != *'#{session_windows}'* ]]; then
      # Bare attached flag (claim pass): 0 detached, 1 attached
      if [[ "$meta" == *detached* ]]; then
        printf '0\n'
      else
        printf '1\n'
      fi
    else
      # Meta blob or multi-field format used by list/rows
      printf '%s\n' "$meta"
    fi
    exit 0
    ;;
  show-options)
    # No claim markers in stub → always empty (claimable)
    exit 0
    ;;
  attach|new-session|set-option|send-keys|new|kill-session)
    exit 0
    ;;
  *)
    # Unknown subcommand: log-only success so tests don't hang
    exit 0
    ;;
esac
