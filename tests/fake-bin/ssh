#!/usr/bin/env bash
# Fake ssh: log invocation; print VERSION for update/doctor cat paths.
# --validate path: exit per FAKE_SSH_VALIDATE_EXIT (default 0); on nonzero print no repo to stderr.
printf '%s\n' "$0 $*" >> "${FAKE_NET_LOG:?FAKE_NET_LOG not set}"
joined="$*"

# Pre-validation: --validate <repo>
if [[ "$joined" == *"--validate"* ]]; then
  exit_code="${FAKE_SSH_VALIDATE_EXIT:-0}"
  if [[ "$exit_code" -ne 0 ]]; then
    # Extract repo token after --validate
    repo=""
    prev=""
    for a in "$@"; do
      if [[ "$prev" == "--validate" ]]; then
        repo="$a"
        break
      fi
      prev="$a"
    done
    printf "no repo '%s'\n" "${repo:-?}" >&2
  fi
  exit "$exit_code"
fi

# `git -C <path> remote` → empty stdout by default (canonical: no remotes).
# When FAKE_SSH_UPSTREAM_EXIT is set, print "origin" so update reaches the
# @{u} check (remote exists but may lack upstream tracking).
# Match trailing ` remote` so we do not swallow `remote show` / similar.
if [[ "$joined" == *" git -C "*remote && "$joined" != *" remote "* ]]; then
  if [[ -n "${FAKE_SSH_UPSTREAM_EXIT+x}" ]]; then
    printf 'origin\n'
  fi
  exit 0
fi
# Upstream detection: git rev-parse … @{u} — exit per FAKE_SSH_UPSTREAM_EXIT
# (default 0 = has upstream). Nonzero = no upstream tracking.
if [[ "$joined" == *"rev-parse"* && "$joined" == *"@{u}"* ]]; then
  exit "${FAKE_SSH_UPSTREAM_EXIT:-0}"
fi
# When args contain both "cat" and "VERSION", print repo VERSION for update/doctor.
if [[ "$joined" == *cat* && "$joined" == *VERSION* ]]; then
  _root="$(cd "$(dirname "$0")/../.." && pwd)"
  if [[ -r "${_root}/VERSION" ]]; then
    tr -d '[:space:]' <"${_root}/VERSION"
    printf '\n'
  else
    printf 'unknown\n'
  fi
fi
exit 0
