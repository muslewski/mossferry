# mossferry configuration — every key is optional; env > file > default.
#FERRY_REMOTE_BIN=".local/bin/repo-session"  # repo-session path, relative to remote $HOME
#FERRY_REPO_BASE="$HOME/Repositories"        # remote: where repos live
#FERRY_DEFAULT_CMD="neofetch"                # remote: startup command in fresh sessions
#                                            # tip: set to "true" or "clear" for quiet panes
#FERRY_DEFAULT_HOST=""                       # local: single host for bare `ferry`
#FERRY_HOST_CANDIDATES=""                    # local: comma-separated ssh aliases tried in
#                                            # order for bare ferry/doctor/update (first
#                                            # BatchMode-reachable wins). Example when home
#                                            # LAN is faster and you still want remote fallback:
#                                            #   FERRY_HOST_CANDIDATES="manjaro,manjaro-remote"
#                                            # with ~/.ssh/config Host manjaro → LAN IP and
#                                            # Host manjaro-remote → Tailscale IP/MagicDNS.
#                                            # Explicit `ferry manjaro-remote` always forces TS.
#FERRY_SERVER_TIMEOUT="86400"                # local: mosh-server self-exit after N s clientless
#FERRY_REMOTE_REPO="Repositories/mossferry"  # remote: repo checkout, relative to remote $HOME
#FERRY_HIDDEN_WINDOW_GLOB="_*"               # skip matching windows in picker names/previews
#FERRY_BANNER="on"                           # green ferry art in picker / --help (off|0 to hide)
#FERRY_START_MENU="claude,grok"              # nested create menu: comma-separated start commands
#                                            # (shown after ➕ destination pick; first row is always
#                                            # "default (no AI)" = FERRY_DEFAULT_CMD). Empty disables
#                                            # the menu. Keep personal profiles (wallet names, etc.)
#                                            # in *your* config — never commit them.
#FERRY_LAUNCHERS=""                         # optional hotkeys: key:command pairs (empty = menu only)
#                                            # e.g. ctrl-a:claude,ctrl-g:grok
#                                            # first colon splits; ctrl-x/ctrl-r reserved
#FERRY_WRAP="auto"                           # local: prefix interactive mosh/ssh with `grok wrap`
#                                            # when local `grok` is on PATH (auto|on|off). Orthogonal
#                                            # to ctrl-g — launchers set the remote start command;
#                                            # wrap is the Mac-side OSC 52 / terminal-restore layer.
#FERRY_TRANSPORT="mosh"                      # local interactive hop: mosh (roam) or ssh (better
#                                            # OSC 52 through grok wrap; no mosh reconnect)
#FERRY_SAGE="auto"                           # remote: wire agentic-sage when `sage` on PATH
#                                            # (picker preview one-liners + ⚖ new judge…).
#                                            # auto|on|off — off hard-kills even if sage installed.

