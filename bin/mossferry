#!/usr/bin/env bash
# mossferry — local client: config, mosh/ssh launch, update, doctor
# shellcheck disable=SC1090,SC1091
set -u

# Symlink-safe path resolution (stock macOS bash 3.2 + Linux).
# Never depends on GNU `readlink -f` (absent on macOS without coreutils).
_ferry_resolve_self() {
  local src="${1:-${BASH_SOURCE[0]}}"
  local dir link max=50
  # Relative invocation → absolute first so -L checks work after cd.
  case "$src" in
    /*) ;;
    *) src="$(pwd)/$src" ;;
  esac
  while [ -L "$src" ] && [ "$max" -gt 0 ]; do
    dir=$(cd "$(dirname "$src")" && pwd) || return 1
    link=$(readlink "$src") || return 1
    case "$link" in
      /*) src=$link ;;
      *) src=$dir/$link ;;
    esac
    max=$((max - 1))
  done
  printf '%s\n' "$src"
}

_ferry_repo_root() {
  local self
  self=$(_ferry_resolve_self "${BASH_SOURCE[0]}") || return 1
  cd "$(dirname "$self")/.." && pwd
}

REPO_ROOT="$(_ferry_repo_root)"

# ---- GREEN-UI-KIT (vendored) — missing lib must NEVER kill the tool --------
_ferry_ui_fallbacks() {
  detect_color() { printf 'none\n'; }
  ui_tty() {
    case ${GREEN_UI_FORCE_TTY-} in
      1) return 0 ;;
      0) return 1 ;;
    esac
    [[ -t 2 ]]
  }
  ui_init() {
    GREEN_UI_MODE=none
    UI_R= UI_G= UI_Y= UI_B= UI_C= UI_M= UI_D= UI_BOLD= UI_Z= UI_A=
    UI_OK='OK' UI_ERR='XX' UI_WARN='!!' UI_PEND='..' UI_RUN='>>'
    UI_SPIN=('|' '/' '-' '\')
    return 0
  }
  banner() {
    local title=${1-} subtitle=${2-}
    printf '+-- %s --+\n' "$title" >&2
    [[ -n $subtitle ]] && printf '| %s\n' "$subtitle" >&2
  }
  ok()   { printf 'OK %s\n' "$*" >&2; }
  warn() { printf '!! %s\n' "$*" >&2; }
  die()  { printf 'XX %s\n' "${1-error}" >&2; exit "${2:-1}"; }
  panel() {
    local title=${1-} line
    printf '+-- %s --+\n' "$title" >&2
    while IFS= read -r line || [[ -n $line ]]; do
      printf '| %s\n' "$line" >&2
    done
    printf '+--------+\n' >&2
  }
  check_set() { printf '%s %s\n' "$2" "$3" >>"$1"; }
  checklist() {
    local sf=$1; shift
    local item id label last line g
    for item in "$@"; do
      id=${item%%:*}; label=${item#*:}; last=pending
      if [[ -f $sf ]]; then
        while IFS= read -r line || [[ -n $line ]]; do
          [[ -z $line ]] && continue
          [[ ${line%% *} == "$id" ]] && last=${line#* }
        done <"$sf"
      fi
      case $last in done) g=OK ;; failed) g=XX ;; *) g=.. ;; esac
      printf '%s %s\n' "$g" "$label" >&2
    done
  }
  ui_cleanup() { return 0; }
}

_ferry_load_ui() {
  local kit="${REPO_ROOT}/lib/green-ui.sh"
  if [[ -r "$kit" ]]; then
    # shellcheck source=lib/green-ui.sh
    source "$kit" || _ferry_ui_fallbacks
  else
    _ferry_ui_fallbacks
  fi
  ui_init
}

_ferry_load_ui

# Client error line: always `mossferry:` prefix; red ✗ when TTY.
_ferry_err() {
  if ui_tty 2>/dev/null; then
    printf '%s%s%s mossferry: %s\n' "${UI_R-}" "${UI_ERR-✗}" "${UI_Z-}" "$*" >&2
  else
    printf 'mossferry: %s\n' "$*" >&2
  fi
}

own_version() {
  local f="$REPO_ROOT/VERSION" v
  if [[ -r "$f" ]]; then
    IFS= read -r v <"$f" || true
    printf '%s\n' "${v:-unknown}"
  else
    printf '%s\n' unknown
  fi
}

# env > config file > built-in default.
# Snapshot pre-set FERRY_* vars, apply defaults, source file, restore snapshot.
load_config() {
  local _had_remote_bin=0 _had_repo_base=0 _had_default_cmd=0
  local _had_default_host=0 _had_server_timeout=0 _had_remote_repo=0
  local _had_banner=0 _had_wrap=0 _had_transport=0
  local _v_remote_bin _v_repo_base _v_default_cmd _v_default_host
  local _v_server_timeout _v_remote_repo _v_banner _v_wrap _v_transport

  if [[ -n "${FERRY_REMOTE_BIN+x}" ]]; then
    _had_remote_bin=1
    _v_remote_bin="$FERRY_REMOTE_BIN"
  fi
  if [[ -n "${FERRY_REPO_BASE+x}" ]]; then
    _had_repo_base=1
    _v_repo_base="$FERRY_REPO_BASE"
  fi
  if [[ -n "${FERRY_DEFAULT_CMD+x}" ]]; then
    _had_default_cmd=1
    _v_default_cmd="$FERRY_DEFAULT_CMD"
  fi
  if [[ -n "${FERRY_DEFAULT_HOST+x}" ]]; then
    _had_default_host=1
    _v_default_host="$FERRY_DEFAULT_HOST"
  fi
  if [[ -n "${FERRY_SERVER_TIMEOUT+x}" ]]; then
    _had_server_timeout=1
    _v_server_timeout="$FERRY_SERVER_TIMEOUT"
  fi
  if [[ -n "${FERRY_REMOTE_REPO+x}" ]]; then
    _had_remote_repo=1
    _v_remote_repo="$FERRY_REMOTE_REPO"
  fi
  if [[ -n "${FERRY_BANNER+x}" ]]; then
    _had_banner=1
    _v_banner="$FERRY_BANNER"
  fi
  if [[ -n "${FERRY_WRAP+x}" ]]; then
    _had_wrap=1
    _v_wrap="$FERRY_WRAP"
  fi
  if [[ -n "${FERRY_TRANSPORT+x}" ]]; then
    _had_transport=1
    _v_transport="$FERRY_TRANSPORT"
  fi

  FERRY_REMOTE_BIN=".local/bin/repo-session"
  FERRY_REPO_BASE="${HOME}/Repositories"
  FERRY_DEFAULT_CMD="neofetch"
  FERRY_DEFAULT_HOST=""
  FERRY_SERVER_TIMEOUT="86400"
  FERRY_REMOTE_REPO="Repositories/mossferry"
  FERRY_BANNER="on"
  # Local: prefix interactive mosh/ssh with `grok wrap` when available.
  # auto = wrap only if `grok` is on PATH; on = require wrap (warn + bare if missing);
  # off = never wrap. Does not apply to --list / doctor / update.
  FERRY_WRAP="auto"
  # Local interactive transport: mosh (default) or ssh. ssh + wrap is best for
  # Grok OSC 52 clipboard; mosh reconnects better but often strips OSC 52.
  FERRY_TRANSPORT="mosh"

  local cfg="${HOME}/.config/mossferry/config"
  if [[ -r "$cfg" ]]; then
    # shellcheck source=/dev/null
    source "$cfg"
  fi

  # Re-apply defaults for any keys the file left unset/empty only if still empty?
  # Spec: file wins over default; missing keys in file keep defaults we set above
  # before source — but source can unset. Re-fill only if completely unset.
  : "${FERRY_REMOTE_BIN:=.local/bin/repo-session}"
  : "${FERRY_REPO_BASE:=${HOME}/Repositories}"
  : "${FERRY_DEFAULT_CMD:=neofetch}"
  : "${FERRY_DEFAULT_HOST:=}"
  : "${FERRY_SERVER_TIMEOUT:=86400}"
  : "${FERRY_REMOTE_REPO:=Repositories/mossferry}"
  : "${FERRY_BANNER:=on}"
  : "${FERRY_WRAP:=auto}"
  : "${FERRY_TRANSPORT:=mosh}"

  [[ $_had_remote_bin -eq 1 ]] && FERRY_REMOTE_BIN="$_v_remote_bin"
  [[ $_had_repo_base -eq 1 ]] && FERRY_REPO_BASE="$_v_repo_base"
  [[ $_had_default_cmd -eq 1 ]] && FERRY_DEFAULT_CMD="$_v_default_cmd"
  [[ $_had_default_host -eq 1 ]] && FERRY_DEFAULT_HOST="$_v_default_host"
  [[ $_had_server_timeout -eq 1 ]] && FERRY_SERVER_TIMEOUT="$_v_server_timeout"
  [[ $_had_remote_repo -eq 1 ]] && FERRY_REMOTE_REPO="$_v_remote_repo"
  [[ $_had_banner -eq 1 ]] && FERRY_BANNER="$_v_banner"
  [[ $_had_wrap -eq 1 ]] && FERRY_WRAP="$_v_wrap"
  [[ $_had_transport -eq 1 ]] && FERRY_TRANSPORT="$_v_transport"
}

# ASCII ferry art for --help (and shared brand with remote picker).
# Keep in sync with bin/repo-session (deliberate duplication — both scripts stay self-contained).
# Keep in sync with bin/repo-session (deliberate duplication — both scripts stay self-contained).
# Optional arg = available display columns; default COLUMNS / tput / 80.
# Tiers: off→nothing; rows<18→SMALL; width≥52→WIDE; width≥24→MEDIUM; else SMALL.
ferry_banner() {
  case "${FERRY_BANNER:-on}" in
    off|0) return 0 ;;
  esac
  local rows width
  rows="${LINES:-$(tput lines 2>/dev/null || echo 24)}"
  width="${1:-${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}}"
  if (( rows < 18 )); then
    # Short panes: one-line variant (green name).
    printf '⛴ \033[1;32mmossferry\033[0m\n'
    return 0
  fi
  if (( width >= 52 )); then
    # WIDE: boat + figlet-wordmark lockup (6×51).
    # flag bright green; boat structure regular green; portholes/waves dim; figlet bright.
    printf '           \033[1;32m|>\033[0m\n'
    printf '\033[32m         __|__               \033[0m\033[1;32m__\033[0m\n'
    printf '\033[32m      __|_\033[0m\033[2;32mo\033[0m\033[32m_\033[0m\033[2;32mo\033[0m\033[32m_|__           \033[0m\033[1;32m/ _|___ _ _ _ _ _  _\033[0m\n'
    printf '\033[32m    _|___________|_        \033[0m\033[1;32m|  _/ -_) '"'"'_| '"'"'_| || |\033[0m\n'
    printf '\033[32m   \\   \033[0m\033[2;32mo\033[0m\033[32m   \033[0m\033[2;32mo\033[0m\033[32m   \033[0m\033[2;32mo\033[0m\033[32m   /       \033[0m\033[1;32m|_| \\___|_| |_|  \\_, |\033[0m\n'
    printf '\033[2;32m ~~~\033[0m\033[32m\\_____________/\033[0m\033[2;32m~~~~~~~~~~~~~~~~~~~~~~~~\033[0m\033[1;32m |__/\033[0m\033[2;32m ~~\033[0m\n'
    return 0
  fi
  if (( width >= 24 )); then
    # MEDIUM: boat liner with name on hull (6×22).
    printf '           \033[1;32m|>\033[0m\n'
    printf '\033[32m         __|__\033[0m\n'
    printf '\033[32m      __|_\033[0m\033[2;32mo\033[0m\033[32m_\033[0m\033[2;32mo\033[0m\033[32m_|__\033[0m\n'
    printf '\033[32m    _|___________|_\033[0m\n'
    printf '\033[32m   \\   \033[0m\033[1;32mmossferry\033[0m\033[32m   /\033[0m\n'
    printf '\033[2;32m ~~~\033[0m\033[32m\\_____________/\033[0m\033[2;32m~~~\033[0m\n'
    return 0
  fi
  # Narrow but tall: SMALL one-liner.
  printf '⛴ \033[1;32mmossferry\033[0m\n'
}

usage() {
  local ver
  ver="$(own_version | tr -d '[:space:]')"
  ferry_banner
  # Section labels green when TTY; body stays plain for pipe/grep stability.
  local H=$'\n' S="" Z=""
  if ui_tty 2>/dev/null && [[ ${GREEN_UI_MODE-none} != none ]]; then
    S="${UI_G-}${UI_BOLD-}"
    Z="${UI_Z-}"
  fi
  cat <<EOF
${S}Usage${Z}
  mossferry <host> [<repo>] [flags]   open a remote tmux session over mosh on <host>
  (\`ferry\` is the short command)

  Default action is the session picker (global with no <repo>, scoped with one).
  Nothing attaches or creates a shared main session implicitly.
  Repo typos are caught locally via automatic pre-validation (no mosh).
  Bare \`ferry\` uses FERRY_DEFAULT_HOST from config/env when set.

${S}Picker keys${Z}
  enter=attach · ctrl-x=kill · ctrl-r=rename · ctrl-a/ctrl-g=AI launchers
  --cycle wraps the list · esc=quit
  (Launchers configurable via FERRY_LAUNCHERS; defaults: ctrl-a:claude, ctrl-g:grok)
  Local: FERRY_WRAP=auto runs interactive sessions under \`grok wrap\` when
  \`grok\` is on PATH (clipboard + terminal restore). FERRY_TRANSPORT=ssh
  forces ssh instead of mosh (better OSC 52 with wrap; no mosh roam).

${S}Flags${Z}
  (none)             open the session picker
  --primary, -p      attach the repo's primary session, creating it if missing
  --new              force a fresh session  (repo, repo-2, repo-3, ...)
  --claude, -c       run \`claude\` in newly-created sessions  (default: neofetch)
  --list, -l         list sessions and exit  (with <repo>: just that repo;
                     without <repo>: every tmux session on the host)
  --resume [N|name]  no arg -> session picker; N -> the Nth session;
                     name -> attach that exact session (e.g. --resume syndcast-2)
  --resume-closed    reattach one EXISTING session per caller, distinct (atomic).
                     Fired across a ghostty-grid each pane gets a different one;
                     panes past the session count stay BLANK.
  --resume-or-new    like --resume-closed, but fill leftover panes with fresh
                     sessions — so an N-pane grid always ends up full.
  -- cmd...          custom startup command for newly-created sessions

  Subcommands:
    update [host]    git pull local clone + remote; print both versions
    doctor [host]    read-only health checks (exit 1 if any FAIL)
    --help, -h       this help (printed locally; no connection)

${S}Config${Z}
  ~/.config/mossferry/config  (FERRY_* keys; env overrides file)
  See config.example and README for the full key list.

${S}Examples${Z}
  ferry manjaro-remote                        global session picker
  ferry manjaro-remote syndcast               scoped picker for syndcast
  ferry manjaro-remote syndcast --primary     attach/create the primary session
  ferry manjaro-remote syndcast --new -c      fresh session running claude
  ferry manjaro-remote syndcast --list        list syndcast's sessions
  ferry manjaro-remote --resume               pick any session
  ferry update                                pull local + remote (default host)
  ferry doctor manjaro-remote                 health checks
  ghostty-grid -8 -- ferry manjaro-remote syndcast --resume-or-new --claude

mossferry ${ver} · the green ferry between your machines
EOF
}

cmd_update() {
  local host="${1:-${FERRY_DEFAULT_HOST:-}}"
  if [[ -z "$host" ]]; then
    _ferry_err "update: no host (pass one or set FERRY_DEFAULT_HOST)"
    return 1
  fi

  local chrome=0
  if ui_tty 2>/dev/null; then
    chrome=1
    banner "ferry update" "$host"
  fi

  # Local pull (no set -e; branch may lack upstream mid-development).
  if (( chrome )); then
    printf '%s%s%s local pull…\n' "${UI_C-}" "${UI_RUN->>}" "${UI_Z-}" >&2
  fi
  local local_ec=0 git_tmp
  if (( chrome )) && [[ -z ${FERRY_UPDATE_VERBOSE-} ]]; then
    git_tmp=$(mktemp 2>/dev/null || printf '/tmp/ferry-update.%s' "$$")
    if git -C "$REPO_ROOT" pull --ff-only >"$git_tmp" 2>&1; then
      local_ec=0
    else
      local_ec=$?
    fi
    while IFS= read -r line || [[ -n ${line-} ]]; do
      [[ -z ${line-} ]] && continue
      printf '%s%s%s\n' "${UI_D-}" "$line" "${UI_Z-}" >&2
    done <"$git_tmp"
    rm -f "$git_tmp"
  else
    git -C "$REPO_ROOT" pull --ff-only || local_ec=$?
  fi
  if (( local_ec != 0 )); then
    _ferry_err "update: local pull failed (continuing)"
    (( chrome )) && printf '%s%s%s local pull\n' "${UI_Y-}" "${UI_WARN-!!}" "${UI_Z-}" >&2
  else
    (( chrome )) && printf '%s%s%s local pull\n' "${UI_G-}" "${UI_OK-OK}" "${UI_Z-}" >&2
  fi

  # Canonical remote checkout (no remotes, or branch has no upstream) cannot pull —
  # skip and continue. Detect upstream via rev-parse @{u} (nonzero = no upstream).
  if (( chrome )); then
    printf '%s%s%s remote pull…\n' "${UI_C-}" "${UI_RUN->>}" "${UI_Z-}" >&2
  fi
  local remotes remote_skipped=0 remote_ec=0
  if ! remotes="$(ssh "$host" git -C "$FERRY_REMOTE_REPO" remote)"; then
    _ferry_err "update: remote pull failed"
    (( chrome )) && printf '%s%s%s remote pull\n' "${UI_R-}" "${UI_ERR-XX}" "${UI_Z-}" >&2
    return 1
  fi
  remotes="${remotes//$'\r'/}"
  if [[ -z "$remotes" ]]; then
    printf '%s\n' "remote checkout is canonical (no upstream) — pull skipped"
    remote_skipped=1
  elif ! ssh "$host" git -C "$FERRY_REMOTE_REPO" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
    printf '%s\n' "remote checkout is canonical (no upstream) — pull skipped"
    remote_skipped=1
  else
    if (( chrome )) && [[ -z ${FERRY_UPDATE_VERBOSE-} ]]; then
      git_tmp=$(mktemp 2>/dev/null || printf '/tmp/ferry-update-r.%s' "$$")
      if ssh "$host" git -C "$FERRY_REMOTE_REPO" pull --ff-only >"$git_tmp" 2>&1; then
        remote_ec=0
      else
        remote_ec=$?
      fi
      while IFS= read -r line || [[ -n ${line-} ]]; do
        [[ -z ${line-} ]] && continue
        printf '%s%s%s\n' "${UI_D-}" "$line" "${UI_Z-}" >&2
      done <"$git_tmp"
      rm -f "$git_tmp"
      if (( remote_ec != 0 )); then
        _ferry_err "update: remote pull failed"
        printf '%s%s%s remote pull\n' "${UI_R-}" "${UI_ERR-XX}" "${UI_Z-}" >&2
        return 1
      fi
    else
      ssh "$host" git -C "$FERRY_REMOTE_REPO" pull --ff-only || {
        _ferry_err "update: remote pull failed"
        return 1
      }
    fi
  fi
  if (( chrome )); then
    if (( remote_skipped )); then
      printf '%s%s%s remote pull (skipped)\n' "${UI_D-}" "${UI_PEND-..}" "${UI_Z-}" >&2
    else
      printf '%s%s%s remote pull\n' "${UI_G-}" "${UI_OK-OK}" "${UI_Z-}" >&2
    fi
  fi

  local v_local v_remote
  v_local="$(own_version | tr -d '[:space:]')"
  v_remote="$(ssh "$host" cat "${FERRY_REMOTE_REPO}/VERSION")"
  v_remote="${v_remote//$'\r'/}"
  v_remote="${v_remote//$'\n'/}"
  v_remote="${v_remote//[[:space:]]/}"

  # Parse-token law: non-TTY (and always) print the slash form on stdout.
  printf 'local %s / remote %s\n' "$v_local" "$v_remote"

  # TTY wave strip on stderr (chrome).
  if (( chrome )); then
    local wave color
    if [[ "$v_local" == "$v_remote" ]]; then
      color="${UI_G-}"
      wave="local ${v_local} ~~~⛴~~~ remote ${v_remote}"
    else
      color="${UI_R-}"
      wave="local ${v_local} ~~~⛴~~~ remote ${v_remote}"
    fi
    printf '%s%s%s\n' "$color" "$wave" "${UI_Z-}" >&2
  fi
}

cmd_doctor() {
  local host="${1:-${FERRY_DEFAULT_HOST:-}}"
  if [[ -z "$host" ]]; then
    _ferry_err "doctor: no host (pass one or set FERRY_DEFAULT_HOST)"
    return 1
  fi

  local failed=0 checks=0 cfg="${HOME}/.config/mossferry/config"
  local chrome=0 version_failed=0
  local fix_hints=()

  if ui_tty 2>/dev/null; then
    chrome=1
    # SMALL one-liner banner tier for doctor
    printf '⛴ %s%smossferry doctor%s · %s\n' "${UI_G-}${UI_BOLD-}" "${UI_Z-}${UI_G-}" "${UI_Z-}" "$host" >&2
  fi

  # Emit one check line. kind = ok|FAIL|info. Non-TTY: exact tokens. TTY: glyph + line.
  _doc_emit() {
    local kind=$1
    shift
    local msg="$*"
    checks=$((checks + 1))
    if (( chrome )); then
      case "$kind" in
        ok)
          printf '%s%s%s ok %s\n' "${UI_G-}" "${UI_OK-OK}" "${UI_Z-}" "$msg"
          ;;
        FAIL)
          printf '%s%s%s FAIL %s\n' "${UI_R-}" "${UI_ERR-XX}" "${UI_Z-}" "$msg"
          ;;
        info)
          printf '%sinfo %s%s\n' "${UI_D-}" "$msg" "${UI_Z-}"
          ;;
        *)
          printf '%s %s\n' "$kind" "$msg"
          ;;
      esac
    else
      printf '%s %s\n' "$kind" "$msg"
    fi
  }

  # 1. config readable (info if absent)
  if [[ -r "$cfg" ]]; then
    _doc_emit ok "config readable: $cfg"
  else
    _doc_emit info "config absent — defaults in use"
  fi

  # 2. ssh -G resolves
  if ssh -G "$host" >/dev/null 2>&1; then
    _doc_emit ok "ssh config resolves host $host"
  else
    _doc_emit FAIL "ssh config does not resolve host $host"
    failed=1
  fi

  # 3. ssh BatchMode connect
  if ssh -o BatchMode=yes -o ConnectTimeout=5 "$host" true >/dev/null 2>&1; then
    _doc_emit ok "ssh BatchMode connect to $host"
  else
    _doc_emit FAIL "ssh BatchMode connect to $host"
    failed=1
  fi

  # 4. local mosh binary
  if command -v mosh >/dev/null 2>&1; then
    _doc_emit ok "local mosh binary"
  else
    _doc_emit FAIL "local mosh binary missing"
    failed=1
  fi

  # 4b. local grok wrap (clipboard / terminal restore for remote TUIs)
  local wrap_mode="${FERRY_WRAP:-auto}"
  case "$wrap_mode" in
    off|0|false|no)
      _doc_emit info "FERRY_WRAP=$wrap_mode — not prefixing transport with grok wrap"
      ;;
    *)
      if command -v grok >/dev/null 2>&1 && grok wrap -h >/dev/null 2>&1; then
        _doc_emit ok "local grok wrap available (FERRY_WRAP=$wrap_mode)"
      elif [[ "$wrap_mode" == on || "$wrap_mode" == 1 || "$wrap_mode" == true || "$wrap_mode" == yes ]]; then
        _doc_emit FAIL "FERRY_WRAP=$wrap_mode but grok not on PATH (curl -fsSL https://x.ai/cli/install.sh | bash)"
        failed=1
      else
        _doc_emit info "grok not on PATH — interactive ferry will not use grok wrap (install Grok CLI on this machine)"
      fi
      ;;
  esac

  # 4c. transport preference
  case "${FERRY_TRANSPORT:-mosh}" in
    ssh|SSH)
      _doc_emit info "FERRY_TRANSPORT=ssh (interactive; better OSC 52 with wrap, no mosh roam)"
      ;;
    mosh|MOSH|"")
      _doc_emit info "FERRY_TRANSPORT=mosh (default; OSC 52 often stripped — keep host clipboard pipes if needed)"
      ;;
    *)
      _doc_emit FAIL "FERRY_TRANSPORT=${FERRY_TRANSPORT} (want mosh|ssh)"
      failed=1
      ;;
  esac

  # 5. remote FERRY_REMOTE_BIN executable (relative to remote $HOME)
  if ssh "$host" "test -x $FERRY_REMOTE_BIN || test -x \"\$HOME/$FERRY_REMOTE_BIN\"" >/dev/null 2>&1; then
    _doc_emit ok "remote $FERRY_REMOTE_BIN executable"
  else
    _doc_emit FAIL "remote $FERRY_REMOTE_BIN not executable"
    failed=1
  fi

  # 6. local vs remote VERSION match
  local v_local v_remote
  v_local="$(own_version | tr -d '[:space:]')"
  v_remote="$(ssh "$host" cat "${FERRY_REMOTE_REPO}/VERSION" 2>/dev/null || true)"
  v_remote="${v_remote//$'\r'/}"
  v_remote="${v_remote//$'\n'/}"
  v_remote="${v_remote//[[:space:]]/}"
  if [[ -n "$v_remote" && "$v_local" == "$v_remote" ]]; then
    _doc_emit ok "versions match: $v_local"
  else
    _doc_emit FAIL "versions: local $v_local / remote ${v_remote:-unknown}"
    failed=1
    version_failed=1
    fix_hints+=("run: ferry update ${host}")
  fi

  # 7. remote fzf (info if missing)
  if ssh "$host" command -v fzf >/dev/null 2>&1; then
    _doc_emit ok "remote fzf present"
  else
    _doc_emit info "remote fzf missing — numbered menu fallback available"
  fi

  # 8. remote mosh-server count (info)
  local count
  count="$(ssh "$host" pgrep -c mosh-server 2>/dev/null || true)"
  count="${count//$'\n'/}"
  : "${count:=0}"
  _doc_emit info "remote mosh-server count: $count"

  # 9. MagicDNS note (info): whether HostName is an IP
  local hostname
  hostname="$(ssh -G "$host" 2>/dev/null | awk 'tolower($1)=="hostname"{print $2; exit}')"
  if [[ -z "$hostname" ]]; then
    _doc_emit info "MagicDNS: could not read HostName for $host"
  elif [[ "$hostname" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    _doc_emit info "MagicDNS: HostName is IP ($hostname) — not using MagicDNS name"
  else
    _doc_emit info "MagicDNS: HostName is $hostname"
  fi

  # TTY summary + fix hints
  if (( chrome )); then
    if (( failed )); then
      printf '%s%d checks · %s failed%s\n' "${UI_R-}" "$checks" "some" "${UI_Z-}" >&2
    else
      printf '%s%s%s %d checks · all ok%s\n' "${UI_G-}" "${UI_OK-OK}" "${UI_Z-}" "$checks" "" >&2
    fi
    local h
    for h in "${fix_hints[@]+"${fix_hints[@]}"}"; do
      printf '%s%s%s\n' "${UI_D-}" "$h" "${UI_Z-}" >&2
    done
  fi

  return "$failed"
}

# First non-flag token after host is the repo (stops at `--`).
# Empty when bare picker / flag-only / cmd-only.
repo_token_from_args() {
  local a
  for a in "$@"; do
    if [[ "$a" == "--" ]]; then
      return 0
    fi
    case "$a" in
      -*) continue ;;
      *)
        printf '%s\n' "$a"
        return 0
        ;;
    esac
  done
}

# True when interactive transport should run under `grok wrap`.
# Local-only: wrap intercepts OSC 52 for Mac clipboard + cleans dirty TUI exits.
# Remote AI launchers (ctrl-g → grok) are orthogonal — they set the start command
# inside tmux; wrap must already surround the whole ferry hop from this machine.
_ferry_should_wrap() {
  case "${FERRY_WRAP:-auto}" in
    off|0|false|no) return 1 ;;
    on|1|true|yes)
      if command -v grok >/dev/null 2>&1; then
        return 0
      fi
      _ferry_err "FERRY_WRAP=on but grok not on PATH — launching without wrap (install: curl -fsSL https://x.ai/cli/install.sh | bash)"
      return 1
      ;;
    auto|*)
      command -v grok >/dev/null 2>&1
      ;;
  esac
}

# Run interactive transport, optionally: grok wrap <mosh|ssh> ...
_ferry_run_transport() {
  if _ferry_should_wrap; then
    grok wrap "$@"
    return $?
  fi
  "$@"
  return $?
}

# Launch remote: ssh for --list/-l; interactive mosh (default) or ssh (FERRY_TRANSPORT).
# Prepends --client-version <v> before user args.
# Repo-bearing interactive launches pre-validate over ssh so typos print locally.
# Interactive hops use FERRY_WRAP (auto → grok wrap when local grok exists).
launch_remote() {
  local host="$1"
  shift
  local ver a repo val_out val_rc=0 transport
  ver="$(own_version)"

  for a in "$@"; do
    case "$a" in
      -h|--help)
        usage
        return 0
        ;;
    esac
  done

  for a in "$@"; do
    case "$a" in
      --list|-l)
        # Non-interactive listing — never wrap (no TUI / no OSC 52).
        ssh "$host" "$FERRY_REMOTE_BIN" --client-version "$ver" "$@"
        return $?
        ;;
    esac
  done

  repo="$(repo_token_from_args "$@")"
  if [[ -n "$repo" ]]; then
    val_out="$(ssh "$host" "$FERRY_REMOTE_BIN" --client-version "$ver" --validate "$repo" 2>&1)" || val_rc=$?
    if [[ $val_rc -ne 0 ]]; then
      [[ -n "$val_out" ]] && printf '%s\n' "$val_out" >&2
      return 1
    fi
  fi

  transport="${FERRY_TRANSPORT:-mosh}"
  case "$transport" in
    ssh|SSH)
      _ferry_run_transport ssh -t "$host" \
        "$FERRY_REMOTE_BIN" --client-version "$ver" "$@"
      return $?
      ;;
    mosh|MOSH|"")
      _ferry_run_transport mosh \
        --server="MOSH_SERVER_NETWORK_TMOUT=${FERRY_SERVER_TIMEOUT} mosh-server" \
        "$host" -- "$FERRY_REMOTE_BIN" --client-version "$ver" "$@"
      return $?
      ;;
    *)
      _ferry_err "unknown FERRY_TRANSPORT='$transport' (want mosh|ssh)"
      return 1
      ;;
  esac
}

main() {
  load_config

  # Subcommand / zero-arg dispatch before host parsing.
  if [[ $# -eq 0 ]]; then
    if [[ -n "${FERRY_DEFAULT_HOST:-}" ]]; then
      set -- "$FERRY_DEFAULT_HOST"
    else
      usage >&2
      return 1
    fi
  fi

  case "$1" in
    -h|--help)
      usage
      return 0
      ;;
    update)
      shift
      cmd_update "$@"
      return $?
      ;;
    doctor)
      shift
      cmd_doctor "$@"
      return $?
      ;;
  esac

  local host="$1"
  shift
  launch_remote "$host" "$@"
}

if [[ "${FERRY_LIB:-}" == "1" ]]; then
  # Sourced as a library: expose load_config / own_version / usage / main.
  return 0 2>/dev/null || true
else
  main "$@"
  exit $?
fi
