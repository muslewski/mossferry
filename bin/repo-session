#!/usr/bin/env bash
# repo-session [repo] [flags] [-- cmd...]
# Remote brain for mossferry: picker, attach/create, atomic grid claim.
#   (default)           fzf/menu picker (scoped to <repo> when given)
#   --primary / -p      attach primary session, create if missing
#   --new               force a fresh session (repo, repo-2, ...)
#   --list / -l         list live sessions and exit
#   --resume [N|name]   bare → picker; N/name → direct attach
#   --resume-closed     atomic claim of one existing session
#   --resume-or-new     claim, or create if none left
#   --claude / -c       run claude on creation
#   --client-version V  version handshake with local mossferry client
#   --validate <repo>   exit 0 if repo dir exists under base; else error (no tmux)
#   --help / -h         usage
#   -- cmd...           custom startup command on creation
# shellcheck disable=SC1090,SC1091
set -u

TMUXBIN="${REPO_SESSION_TMUXBIN:-/usr/bin/tmux}"

# Populated by parse_launchers (after load_config). Empty = feature off.
LAUNCHER_KEYS=()
LAUNCHER_CMDS=()

# Symlink-safe path resolution (stock macOS bash 3.2 + Linux).
# Never depends on GNU `readlink -f`.
_ferry_resolve_self() {
  local src="${1:-${BASH_SOURCE[0]}}"
  local dir link max=50
  case "$src" in
    /*) ;;
    *) src="$(pwd)/$src" ;;
  esac
  while [ -L "$src" ] && [ "$max" -gt 0 ]; do
    dir=$(cd "$(dirname "$src")" && pwd) || return 1
    link=$(readlink "$src") || return 1
    case "$link" in
      /*) src=$link ;;
      *) src=$dir/$link ;;
    esac
    max=$((max - 1))
  done
  printf '%s\n' "$src"
}

_ferry_repo_root() {
  local self
  self=$(_ferry_resolve_self "${BASH_SOURCE[0]}") || return 1
  cd "$(dirname "$self")/.." && pwd
}

REPO_ROOT="$(_ferry_repo_root)"

# ---- GREEN-UI-KIT (vendored) — missing lib must NEVER kill the tool --------
_ferry_ui_fallbacks() {
  detect_color() { printf 'none\n'; }
  ui_tty() {
    case ${GREEN_UI_FORCE_TTY-} in
      1) return 0 ;;
      0) return 1 ;;
    esac
    [[ -t 2 ]]
  }
  ui_init() {
    GREEN_UI_MODE=none
    UI_R= UI_G= UI_Y= UI_B= UI_C= UI_M= UI_D= UI_BOLD= UI_Z= UI_A=
    UI_OK='OK' UI_ERR='XX' UI_WARN='!!' UI_PEND='..' UI_RUN='>>'
    UI_SPIN=('|' '/' '-' '\')
    return 0
  }
  banner() {
    local title=${1-} subtitle=${2-}
    printf '+-- %s --+\n' "$title" >&2
    [[ -n $subtitle ]] && printf '| %s\n' "$subtitle" >&2
  }
  ok()   { printf 'OK %s\n' "$*" >&2; }
  warn() { printf '!! %s\n' "$*" >&2; }
  die()  { printf 'XX %s\n' "${1-error}" >&2; exit "${2:-1}"; }
  panel() {
    local title=${1-} line
    printf '+-- %s --+\n' "$title" >&2
    while IFS= read -r line || [[ -n $line ]]; do
      printf '| %s\n' "$line" >&2
    done
    printf '+--------+\n' >&2
  }
  ui_cleanup() { return 0; }
}

_ferry_load_ui() {
  local kit="${REPO_ROOT}/lib/green-ui.sh"
  if [[ -r "$kit" ]]; then
    # shellcheck source=lib/green-ui.sh
    source "$kit" || _ferry_ui_fallbacks
  else
    _ferry_ui_fallbacks
  fi
  ui_init
}

_ferry_load_ui

# Remote error line: always `repo-session:` prefix; red ✗ when TTY.
_rs_err() {
  if ui_tty 2>/dev/null; then
    printf '%s%s%s repo-session: %s\n' "${UI_R-}" "${UI_ERR-✗}" "${UI_Z-}" "$*" >&2
  else
    printf 'repo-session: %s\n' "$*" >&2
  fi
}

# ---- config / version helpers ------------------------------------------------

load_config() {
  # Snapshot env (env > file > default).
  local e_REMOTE_BIN e_REPO_BASE e_DEFAULT_CMD e_DEFAULT_HOST e_SERVER_TIMEOUT e_REMOTE_REPO
  local e_HIDDEN_WINDOW_GLOB e_BANNER e_LAUNCHERS
  e_REMOTE_BIN="${FERRY_REMOTE_BIN-__UNSET__}"
  e_REPO_BASE="${FERRY_REPO_BASE-__UNSET__}"
  e_DEFAULT_CMD="${FERRY_DEFAULT_CMD-__UNSET__}"
  e_DEFAULT_HOST="${FERRY_DEFAULT_HOST-__UNSET__}"
  e_SERVER_TIMEOUT="${FERRY_SERVER_TIMEOUT-__UNSET__}"
  e_REMOTE_REPO="${FERRY_REMOTE_REPO-__UNSET__}"
  e_HIDDEN_WINDOW_GLOB="${FERRY_HIDDEN_WINDOW_GLOB-__UNSET__}"
  e_BANNER="${FERRY_BANNER-__UNSET__}"
  e_LAUNCHERS="${FERRY_LAUNCHERS-__UNSET__}"

  FERRY_REMOTE_BIN=".local/bin/repo-session"
  FERRY_REPO_BASE="${HOME}/Repositories"
  FERRY_DEFAULT_CMD="neofetch"
  FERRY_DEFAULT_HOST=""
  FERRY_SERVER_TIMEOUT="86400"
  FERRY_REMOTE_REPO="Repositories/mossferry"
  FERRY_HIDDEN_WINDOW_GLOB="_*"
  FERRY_BANNER="on"
  FERRY_LAUNCHERS="ctrl-a:claude,ctrl-g:grok"

  if [[ -r "${HOME}/.config/mossferry/config" ]]; then
    # shellcheck source=/dev/null
    source "${HOME}/.config/mossferry/config"
  fi

  [[ "$e_REMOTE_BIN" != "__UNSET__" ]] && FERRY_REMOTE_BIN="$e_REMOTE_BIN"
  [[ "$e_REPO_BASE" != "__UNSET__" ]] && FERRY_REPO_BASE="$e_REPO_BASE"
  [[ "$e_DEFAULT_CMD" != "__UNSET__" ]] && FERRY_DEFAULT_CMD="$e_DEFAULT_CMD"
  [[ "$e_DEFAULT_HOST" != "__UNSET__" ]] && FERRY_DEFAULT_HOST="$e_DEFAULT_HOST"
  [[ "$e_SERVER_TIMEOUT" != "__UNSET__" ]] && FERRY_SERVER_TIMEOUT="$e_SERVER_TIMEOUT"
  [[ "$e_REMOTE_REPO" != "__UNSET__" ]] && FERRY_REMOTE_REPO="$e_REMOTE_REPO"
  [[ "$e_HIDDEN_WINDOW_GLOB" != "__UNSET__" ]] && FERRY_HIDDEN_WINDOW_GLOB="$e_HIDDEN_WINDOW_GLOB"
  [[ "$e_BANNER" != "__UNSET__" ]] && FERRY_BANNER="$e_BANNER"
  [[ "$e_LAUNCHERS" != "__UNSET__" ]] && FERRY_LAUNCHERS="$e_LAUNCHERS"
}

# Parse FERRY_LAUNCHERS into LAUNCHER_KEYS / LAUNCHER_CMDS (parallel arrays).
# Empty value → both empty (feature off). Invalid/reserved pairs skipped.
# Split each pair on the FIRST colon so commands may contain args/spaces.
parse_launchers() {
  LAUNCHER_KEYS=()
  LAUNCHER_CMDS=()
  local raw="${FERRY_LAUNCHERS:-}"
  [[ -z "$raw" ]] && return 0

  local pair key cmd
  # Trailing newline so the last pair is not dropped by `read`.
  while IFS= read -r pair || [[ -n "${pair:-}" ]]; do
    [[ -z "$pair" ]] && continue
    [[ "$pair" != *:* ]] && continue
    key="${pair%%:*}"
    cmd="${pair#*:}"
    [[ -z "$key" || -z "$cmd" ]] && continue
    # Reserved for kill/rename in the main picker.
    [[ "$key" == "ctrl-x" || "$key" == "ctrl-r" ]] && continue
    # Valid fzf-bindable keys only.
    if [[ "$key" =~ ^ctrl-[a-z]$ ]] \
       || [[ "$key" =~ ^alt-[a-z]$ ]] \
       || [[ "$key" =~ ^f([1-9]|1[0-2])$ ]]; then
      LAUNCHER_KEYS+=("$key")
      LAUNCHER_CMDS+=("$cmd")
    fi
  done < <(printf '%s\n' "$raw" | tr ',' '\n')
}

# Print the start command for a launcher key. Exit 1 if unknown.
launcher_cmd() {
  local want="${1:-}" i
  [[ -z "$want" ]] && return 1
  for i in "${!LAUNCHER_KEYS[@]}"; do
    if [[ "${LAUNCHER_KEYS[$i]}" == "$want" ]]; then
      printf '%s\n' "${LAUNCHER_CMDS[$i]}"
      return 0
    fi
  done
  return 1
}

# Comma-separated --expect list: ctrl-x,ctrl-r[,launcher keys...]
_launcher_expect_suffix() {
  local k out=""
  for k in "${LAUNCHER_KEYS[@]+"${LAUNCHER_KEYS[@]}"}"; do
    out+=",$k"
  done
  printf '%s' "$out"
}

# Sub-picker hints: enter=<default> · key=cmd · ...
_subpicker_hints() {
  local i line
  line="enter=${FERRY_DEFAULT_CMD:-neofetch}"
  for i in "${!LAUNCHER_KEYS[@]}"; do
    line+=" · ${LAUNCHER_KEYS[$i]}=${LAUNCHER_CMDS[$i]}"
  done
  printf '%s' "$line"
}

# ASCII ferry art for picker header / --help / no-fzf menu.
# Keep in sync with bin/mossferry (deliberate duplication — both scripts stay self-contained).
# Optional arg = available display columns; default COLUMNS / tput / 80.
# Tiers: off→nothing; rows<18→SMALL; width≥52→WIDE; width≥24→MEDIUM; else SMALL.
ferry_banner() {
  case "${FERRY_BANNER:-on}" in
    off|0) return 0 ;;
  esac
  local rows width
  rows="${LINES:-$(tput lines 2>/dev/null || echo 24)}"
  width="${1:-${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}}"
  if (( rows < 18 )); then
    # Short panes: one-line variant (green name).
    printf '⛴ \033[1;32mmossferry\033[0m\n'
    return 0
  fi
  if (( width >= 52 )); then
    # WIDE: boat + figlet-wordmark lockup (6×51).
    # flag bright green; boat structure regular green; portholes/waves dim; figlet bright.
    printf '           \033[1;32m|>\033[0m\n'
    printf '\033[32m         __|__               \033[0m\033[1;32m__\033[0m\n'
    printf '\033[32m      __|_\033[0m\033[2;32mo\033[0m\033[32m_\033[0m\033[2;32mo\033[0m\033[32m_|__           \033[0m\033[1;32m/ _|___ _ _ _ _ _  _\033[0m\n'
    printf '\033[32m    _|___________|_        \033[0m\033[1;32m|  _/ -_) '"'"'_| '"'"'_| || |\033[0m\n'
    printf '\033[32m   \\   \033[0m\033[2;32mo\033[0m\033[32m   \033[0m\033[2;32mo\033[0m\033[32m   \033[0m\033[2;32mo\033[0m\033[32m   /       \033[0m\033[1;32m|_| \\___|_| |_|  \\_, |\033[0m\n'
    printf '\033[2;32m ~~~\033[0m\033[32m\\_____________/\033[0m\033[2;32m~~~~~~~~~~~~~~~~~~~~~~~~\033[0m\033[1;32m |__/\033[0m\033[2;32m ~~\033[0m\n'
    return 0
  fi
  if (( width >= 24 )); then
    # MEDIUM: boat liner with name on hull (6×22).
    printf '           \033[1;32m|>\033[0m\n'
    printf '\033[32m         __|__\033[0m\n'
    printf '\033[32m      __|_\033[0m\033[2;32mo\033[0m\033[32m_\033[0m\033[2;32mo\033[0m\033[32m_|__\033[0m\n'
    printf '\033[32m    _|___________|_\033[0m\n'
    printf '\033[32m   \\   \033[0m\033[1;32mmossferry\033[0m\033[32m   /\033[0m\n'
    printf '\033[2;32m ~~~\033[0m\033[32m\\_____________/\033[0m\033[2;32m~~~\033[0m\n'
    return 0
  fi
  # Narrow but tall: SMALL one-liner.
  printf '⛴ \033[1;32mmossferry\033[0m\n'
}

# Closest repo name for did-you-mean (prefix / substring / common-prefix score).
_ferry_closest_repo() {
  local want=$1
  shift
  local cand best="" best_score=-1 score i m
  local wlen=${#want}
  (( wlen == 0 )) && return 1
  for cand in "$@"; do
    score=0
    if [[ "$cand" == "$want" ]]; then
      printf '%s\n' "$cand"
      return 0
    fi
    # prefix either way
    if [[ "$cand" == "$want"* ]]; then
      score=$((100 + ${#want}))
    elif [[ "$want" == "$cand"* ]]; then
      score=$((90 + ${#cand}))
    elif [[ "$cand" == *"$want"* ]]; then
      score=$((50 + ${#want}))
    elif [[ "$want" == *"$cand"* ]]; then
      score=$((40 + ${#cand}))
    else
      m=$wlen
      (( ${#cand} < m )) && m=${#cand}
      score=0
      for (( i = 0; i < m; i++ )); do
        if [[ "${cand:i:1}" == "${want:i:1}" ]]; then
          score=$((score + 1))
        else
          break
        fi
      done
      # length proximity bonus for 1-char typos
      local d=$(( ${#cand} - wlen ))
      (( d < 0 )) && d=$(( -d ))
      if (( d <= 1 && score >= 3 )); then
        score=$((score + 20))
      fi
    fi
    if (( score > best_score )); then
      best_score=$score
      best=$cand
    fi
  done
  # require a minimum signal so random names don't get silly hints
  if [[ -n "$best" ]] && (( best_score >= 3 )); then
    printf '%s\n' "$best"
    return 0
  fi
  return 1
}

# Exit 0 if $FERRY_REPO_BASE/<repo> is a directory; else stderr error + list, return 1.
# Never invokes tmux.
# PARSE-TOKEN: first error line is byte-stable. TTY adds dim capped list + did-you-mean.
validate_repo() {
  local r="$1"
  local dir="${FERRY_REPO_BASE}/${r}"
  if [[ ! -d "$dir" ]]; then
    # Exact first-line token (tests + client pre-validate assert this).
    echo "repo-session: no repo '${r}' under ${FERRY_REPO_BASE} — pick one below, or run 'ferry <host>' to browse all sessions" >&2

    local -a repos=()
    local line n=0 cap=20 closest
    while IFS= read -r line || [[ -n ${line-} ]]; do
      [[ -z ${line-} ]] && continue
      repos+=("$line")
    done < <(ls -1 "$FERRY_REPO_BASE" 2>/dev/null || true)

    if ui_tty 2>/dev/null; then
      for line in "${repos[@]+"${repos[@]}"}"; do
        if (( n < cap )); then
          printf '%s  %s%s\n' "${UI_D-}" "$line" "${UI_Z-}" >&2
        fi
        n=$((n + 1))
      done
      if (( n > cap )); then
        printf '%s  …and %d more%s\n' "${UI_D-}" "$((n - cap))" "${UI_Z-}" >&2
      fi
      if closest=$(_ferry_closest_repo "$r" "${repos[@]+"${repos[@]}"}"); then
        printf '%s did you mean %s?%s\n' "${UI_D-}" "$closest" "${UI_Z-}" >&2
      fi
    else
      for line in "${repos[@]+"${repos[@]}"}"; do
        printf '  %s\n' "$line" >&2
      done
    fi
    return 1
  fi
  return 0
}

own_version() {
  local vf="${REPO_ROOT}/VERSION"
  if [[ -r "$vf" ]]; then
    cat "$vf"
  else
    printf 'unknown\n'
  fi
}

# Hermes coding-ops registry (same host as tmux). Override with FERRY_CCOPS_STATE.
_ferry_ccops_state() {
  printf '%s\n' "${FERRY_CCOPS_STATE:-$HOME/.hermes/state/ccops}"
}

# Badge from registry for a ccops-* tmux session (status or empty).
_ferry_ccops_badge() {
  local sess="$1" active st
  active="$(_ferry_ccops_state)/active.json"
  [[ -r "$active" ]] || return 0
  st=$(python3 -c "
import json,sys
try:
  d=json.load(open(sys.argv[1]))
  for j in d.get('jobs') or []:
    if j.get('tmux')==sys.argv[2]:
      print(j.get('status') or '')
      break
except Exception:
  pass
" "$active" "$sess" 2>/dev/null || true)
  [[ -n "$st" ]] && printf '%s' "$st"
}

# One line per live session (optionally scoped to <repo>):
#   <session>\t<display_window>\t<N>w\t<attached|detached>\t<cmd>\t<preview_target>
# Display window skips FERRY_HIDDEN_WINDOW_GLOB (default _*); preview_target is session:index.
# Hermes coding-ops sessions (ccops-<repo>-*) are included when filter matches that repo
# or when browsing globally; display window prefixed with hermes:status for ferry visibility.
build_session_rows() {
  local filter="${1:-}" s cname wins att cmd attword
  local active_name active_idx display_name preview_target glob wline widx wname found
  local -a names=()
  local badge
  glob="${FERRY_HIDDEN_WINDOW_GLOB:-_*}"
  if [[ -n "$filter" ]]; then
    # Classic repo sessions + Hermes coding-ops for that repo
    mapfile -t names < <("$TMUXBIN" list-sessions -F '#{session_name}' 2>/dev/null \
      | grep -E "^(${filter}(-[0-9]+)?|ccops-${filter}-.+)$" | sort -V)
  else
    mapfile -t names < <("$TMUXBIN" list-sessions -F '#{session_name}' 2>/dev/null | sort -V)
  fi
  for s in "${names[@]}"; do
    [[ -z "$s" ]] && continue
    # Hide coding-ops monitor side-sessions (ccops-*-mon) — attach the main job session only
    [[ "$s" == *-mon || "$s" == *-mon-* ]] && continue
    active_name=$("$TMUXBIN" display-message -p -t "$s" '#{window_name}')
    active_idx=$("$TMUXBIN" display-message -p -t "$s" '#{window_index}')
    wins=$("$TMUXBIN" display-message -p -t "$s" '#{session_windows}')
    att=$("$TMUXBIN" display-message -p -t "$s" '#{session_attached}')
    cmd=$("$TMUXBIN" display-message -p -t "$s" '#{pane_current_command}')
    if [[ "$att" == "0" ]]; then attword="detached"; else attword="attached"; fi

    display_name="$active_name"
    preview_target="${s}:${active_idx}"
    # If active window is hidden, fall back to first non-matching window by index.
    if [[ "$active_name" == $glob ]]; then
      found=0
      while IFS= read -r wline; do
        [[ -z "$wline" ]] && continue
        widx="${wline%%:*}"
        wname="${wline#*:}"
        if [[ "$wname" != $glob ]]; then
          display_name="$wname"
          preview_target="${s}:${widx}"
          found=1
          break
        fi
      done < <("$TMUXBIN" list-windows -t "$s" -F '#{window_index}:#{window_name}' 2>/dev/null)
      # all-matching → keep active as-is (found stays 0)
      :
    fi

    # Badge Hermes coding sessions so they stand out in ferry picker
    if [[ "$s" == ccops-* ]]; then
      badge="$(_ferry_ccops_badge "$s")"
      if [[ -n "$badge" ]]; then
        display_name="hermes:${badge}:${display_name}"
      else
        display_name="hermes:${display_name}"
      fi
    fi

    printf '%s\t%s\t%sw\t%s\t%s\t%s\n' "$s" "$display_name" "$wins" "$attword" "$cmd" "$preview_target"
  done
}

picker_kill() {
  "$TMUXBIN" kill-session -t "=$1"
}

picker_rename() {
  "$TMUXBIN" rename-session -t "=$1" "$2"
}

# Create a new git repo under FERRY_REPO_BASE. No tmux.
# Name must match ^[A-Za-z0-9][A-Za-z0-9._-]*$. Returns 1 on invalid/existing.
create_repo() {
  local name="$1"
  local dir
  if [[ -z "$name" || ! "$name" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]; then
    echo "repo-session: invalid repo name '${name}'" >&2
    return 1
  fi
  dir="${FERRY_REPO_BASE}/${name}"
  if [[ -e "$dir" ]]; then
    echo "repo-session: already exists: ${dir}" >&2
    return 1
  fi
  mkdir -p "$dir" || return 1
  git -C "$dir" init -q -b main || {
    echo "repo-session: git init failed for '${name}'" >&2
    return 1
  }
  return 0
}

# Create (if missing) + attach a session with cwd $HOME. -A semantics.
# Honours startcmd / FERRY_DEFAULT_CMD when creating. Name regex same as create_repo.
create_home_session() {
  local session_name="${1:-home}"
  if [[ -z "$session_name" || ! "$session_name" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]]; then
    echo "repo-session: invalid session name '${session_name}'" >&2
    return 1
  fi
  if ! "$TMUXBIN" has-session -t "=$session_name" 2>/dev/null; then
    "$TMUXBIN" new-session -d -s "$session_name" -c "$HOME"
    "$TMUXBIN" send-keys -t "$session_name" "${startcmd:-${FERRY_DEFAULT_CMD:-neofetch}}" C-m
  fi
  exec "$TMUXBIN" attach -t "$session_name"
}

# ---- session helpers ---------------------------------------------------------

_list_repo_sessions() {
  # populate global `sessions` array for $repo
  mapfile -t sessions < <("$TMUXBIN" list-sessions -F '#{session_name}' 2>/dev/null \
    | grep -E "^${repo}(-[0-9]+)?$" | sort -V)
}

# Numbered list for --list. Window column uses build_session_rows (hidden-window rule).
print_list() {
  local i=1 s cname wins att cmd _preview
  while IFS=$'\t' read -r s cname wins att cmd _preview; do
    [[ -z "$s" ]] && continue
    printf '%d) %-16s %-22s %s\n' "$i" "$s" "$cname" "$wins $att $cmd"
    ((i++)) || true
  done < <(build_session_rows "${repo:-}")
}

# Lock-guarded create of $session in $dir if missing; leaves lock held by caller
# only when caller already holds fd 9. This helper acquires and releases its own.
_create_session_locked() {
  # args: session_name
  local session_name="$1"
  local dir="${FERRY_REPO_BASE}/${repo}"
  local lockf="${TMPDIR:-/tmp}/repo-session-${repo}.claim"
  exec 9>"$lockf"
  flock 9
  if ! "$TMUXBIN" has-session -t "$session_name" 2>/dev/null; then
    "$TMUXBIN" new-session -d -s "$session_name" -c "$dir"
    "$TMUXBIN" send-keys -t "$session_name" "${startcmd:-$FERRY_DEFAULT_CMD}" C-m
  fi
  flock -u 9
}

_next_free_name() {
  # print next free session name for $repo (primary if free)
  local session="$repo" n=2
  while "$TMUXBIN" has-session -t "$session" 2>/dev/null; do
    session="${repo}-${n}"
    ((n++)) || true
  done
  printf '%s\n' "$session"
}

_attach() {
  # exact match when name known
  exec "$TMUXBIN" attach -t "=$1"
}

_create_and_attach() {
  local session_name="$1"
  _create_session_locked "$session_name"
  exec "$TMUXBIN" attach -t "$session_name"
}

# ---- picker ------------------------------------------------------------------

# Special tokens returned by _pick_repo_for_new (global chain only).
_NEW_REPO_LABEL=$'➕ new repo…'
_HOME_SESSION_LABEL=$'🏠 home session…'
_TOKEN_NEW_REPO='__NEW_REPO__'
_TOKEN_HOME='__HOME__'

_pick_repo_for_new() {
  # Print chosen repo name (or special token) to stdout, or return 1 on cancel.
  # Global chain: repo dirs + new-repo + home-session rows.
  # Repo-scoped: pre-filtered to that repo only — no special rows.
  local -a dirs=()
  local d choice i scoped=0
  if [[ -n "$repo" ]]; then
    dirs=("$repo")
    scoped=1
  else
    if [[ -d "$FERRY_REPO_BASE" ]]; then
      while IFS= read -r d; do
        [[ -n "$d" ]] && dirs+=("$d")
      done < <(ls -1 "$FERRY_REPO_BASE" 2>/dev/null)
    fi
  fi
  if (( scoped == 0 && ${#dirs[@]} == 0 )); then
    # Global with no existing repos: still offer new-repo / home rows.
    :
  elif (( scoped == 1 && ${#dirs[@]} == 0 )); then
    echo "repo-session: no repos under $FERRY_REPO_BASE" >&2
    return 1
  fi

  if command -v fzf >/dev/null 2>&1 && [[ -z "${FERRY_NO_FZF:-}" ]]; then
    local banner sub_hdr=() sub_expect=() header hints pickfile key lc
    banner=$(ferry_banner) || true
    if (( ${#LAUNCHER_KEYS[@]} > 0 )); then
      hints=$(_subpicker_hints)
      if [[ -n "$banner" ]]; then
        header="${banner}"$'\n'"${hints}"
      else
        header="$hints"
      fi
      sub_hdr=(--header "$header")
      sub_expect=(--expect="$(_launcher_expect_suffix | sed 's/^,//')")
    elif [[ -n "$banner" ]]; then
      sub_hdr=(--header "$banner")
    fi
    pickfile="${TMPDIR:-/tmp}/repo-session-subpick.$$"
    if (( scoped )); then
      printf '%s\n' "${dirs[@]}" | fzf --layout=reverse --header-first --cycle \
        "${sub_hdr[@]}" "${sub_expect[@]}" --prompt='new session repo> ' \
        >"$pickfile" || { rm -f "$pickfile"; return 1; }
    else
      {
        printf '%s\n' "${dirs[@]}"
        printf '%s\n' "$_NEW_REPO_LABEL"
        printf '%s\n' "$_HOME_SESSION_LABEL"
      } | fzf --layout=reverse --header-first --cycle \
        "${sub_hdr[@]}" "${sub_expect[@]}" --prompt='new session repo> ' \
        >"$pickfile" || { rm -f "$pickfile"; return 1; }
    fi
    if (( ${#LAUNCHER_KEYS[@]} > 0 )); then
      key=$(head -n 1 "$pickfile")
      choice=$(sed -n '2p' "$pickfile")
      if [[ -n "$key" ]] && lc=$(launcher_cmd "$key"); then
        startcmd="$lc"
      fi
    else
      choice=$(cat "$pickfile")
    fi
    rm -f "$pickfile"
    if [[ "$choice" == "$_NEW_REPO_LABEL" ]]; then
      printf '%s\n' "$_TOKEN_NEW_REPO"
    elif [[ "$choice" == "$_HOME_SESSION_LABEL" ]]; then
      printf '%s\n' "$_TOKEN_HOME"
    else
      printf '%s\n' "$choice"
    fi
    return 0
  fi

  # numbered menu (no-fzf)
  i=1
  for d in "${dirs[@]}"; do
    printf '%d) %s\n' "$i" "$d" >&2
    ((i++)) || true
  done
  if (( ! scoped )); then
    printf 'r) new repo\n' >&2
    printf 'h) home session\n' >&2
  fi
  printf 'q) quit\n' >&2
  if ! read -r choice; then
    return 1
  fi
  case "$choice" in
    q|Q|"") return 1 ;;
    r|R)
      if (( ! scoped )); then
        printf '%s\n' "$_TOKEN_NEW_REPO"
        return 0
      fi
      return 1
      ;;
    h|H)
      if (( ! scoped )); then
        printf '%s\n' "$_TOKEN_HOME"
        return 0
      fi
      return 1
      ;;
    *)
      if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#dirs[@]} )); then
        printf '%s\n' "${dirs[$((choice-1))]}"
        return 0
      fi
      return 1
      ;;
  esac
}

# Prompt for new repo name, create_repo, then lock-guarded create+attach.
# Returns 1 on invalid (message already printed) so caller can reload picker.
_flow_new_repo() {
  local name session_name
  printf 'new repo name: ' >/dev/tty
  if ! read -r name </dev/tty; then
    return 1
  fi
  if ! create_repo "$name"; then
    return 1
  fi
  repo="$name"
  session_name=$(_next_free_name)
  _create_and_attach "$session_name"
}

# Prompt for home session name (empty → home), then create_home_session.
# Returns 1 on invalid so caller can reload picker.
_flow_home_session() {
  local name
  printf 'session name [home]: ' >/dev/tty
  if ! read -r name </dev/tty; then
    return 1
  fi
  [[ -z "$name" ]] && name="home"
  create_home_session "$name" || return 1
}

# Returns 1 on invalid input (reload picker); exits 130 on cancel; execs on success.
_do_new_session_flow() {
  local chosen name
  chosen=$(_pick_repo_for_new) || exit 130
  [[ -z "$chosen" ]] && exit 130

  case "$chosen" in
    "$_TOKEN_NEW_REPO")
      _flow_new_repo || return 1
      return 0
      ;;
    "$_TOKEN_HOME")
      _flow_home_session || return 1
      return 0
      ;;
  esac

  if [[ ! -d "${FERRY_REPO_BASE}/${chosen}" ]]; then
    echo "repo-session: no repo '${chosen}' under $FERRY_REPO_BASE" >&2
    return 1
  fi
  repo="$chosen"
  name=$(_next_free_name)
  _create_and_attach "$name"
}

run_picker() {
  # Uses global $repo (may be empty = global).
  local -a rows=()
  local line choice name i nsel key ans newname pickfile
  local new_label=$'➕ new session…'
  local is_new=0

  # Numbered menu fallback: loop so invalid create-flow input reloads.
  if ! command -v fzf >/dev/null 2>&1 || [[ -n "${FERRY_NO_FZF:-}" ]]; then
    while true; do
      rows=()
      while IFS= read -r line; do
        [[ -n "$line" ]] && rows+=("$line")
      done < <(build_session_rows "$repo")
      ferry_banner
      i=1
      for line in "${rows[@]}"; do
        name="${line%%$'\t'*}"
        printf '%d) %s\n' "$i" "$line" | tr '\t' ' '
        ((i++)) || true
      done
      printf 'n) new session…\n'
      printf 'q) quit\n'
      if ! read -r nsel; then
        exit 130
      fi
      case "$nsel" in
        q|Q|"") exit 130 ;;
        n|N)
          # On invalid name: message already printed; reload this menu.
          _do_new_session_flow || continue
          ;;
        *)
          if [[ "$nsel" =~ ^[0-9]+$ ]] && (( nsel >= 1 && nsel <= ${#rows[@]} )); then
            line="${rows[$((nsel-1))]}"
            name="${line%%$'\t'*}"
            exec "$TMUXBIN" attach -t "=$name"
          fi
          echo "repo-session: invalid selection" >&2
          continue
          ;;
      esac
    done
    return
  fi

  # fzf path: loop so kill/rename / invalid create can reload the list.
  pickfile="${TMPDIR:-/tmp}/repo-session-pick.$$"
  local banner hints header expect_keys lc
  hints='enter=attach · ctrl-x=kill · ctrl-r=rename · esc=quit'
  expect_keys="ctrl-x,ctrl-r$(_launcher_expect_suffix)"
  while true; do
    rows=()
    while IFS= read -r line; do
      [[ -n "$line" ]] && rows+=("$line")
    done < <(build_session_rows "$repo")

    # Header lives left of right:60% preview → banner width is 40% of cols.
    local cols banner_w
    cols="${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}"
    banner_w=$(( cols * 40 / 100 ))
    banner=$(ferry_banner "$banner_w") || true
    if [[ -n "$banner" ]]; then
      header="${banner}"$'\n'"${hints}"
    else
      header="$hints"
    fi

    {
      printf '%s\n' "${rows[@]}"
      printf '%s\n' "$new_label"
    } | fzf --ansi --delimiter=$'\t' \
        --layout=reverse --header-first --cycle \
        --expect="$expect_keys" \
        --header "$header" \
        --preview "$TMUXBIN capture-pane -ep -t {6}" \
        --preview-window=right:60% \
        >"$pickfile" || {
      rm -f "$pickfile"
      exit 130
    }

    key=$(head -n 1 "$pickfile")
    choice=$(sed -n '2p' "$pickfile")
    rm -f "$pickfile"

    is_new=0
    if [[ "$choice" == "$new_label" || "$choice" == *$'\t'"$new_label" || "$choice" == "➕ new session…" ]]; then
      is_new=1
    fi

    # Action keys on the new-session row: ignore and reload.
    if (( is_new )) && [[ "$key" == "ctrl-x" || "$key" == "ctrl-r" ]]; then
      continue
    fi

    if (( is_new )); then
      # Launcher key arms start command for this one creation (overrides flags).
      if [[ -n "$key" ]] && lc=$(launcher_cmd "$key"); then
        startcmd="$lc"
      fi
      # Success execs attach; cancel exits 130; invalid returns → reload.
      _do_new_session_flow || continue
      continue
    fi

    name="${choice%%$'\t'*}"
    [[ -z "$name" ]] && exit 130

    case "$key" in
      ctrl-x)
        printf 'kill %s? [y/N] ' "$name" >/dev/tty
        if ! read -r ans </dev/tty; then
          continue
        fi
        if [[ "$ans" == "y" || "$ans" == "Y" ]]; then
          picker_kill "$name"
        fi
        continue
        ;;
      ctrl-r)
        printf 'new name: ' >/dev/tty
        if ! read -r newname </dev/tty; then
          continue
        fi
        if [[ -n "$newname" ]]; then
          picker_rename "$name" "$newname"
        fi
        continue
        ;;
      *)
        # Launcher keys on existing-session rows: ignore, reload.
        if [[ -n "$key" ]] && launcher_cmd "$key" >/dev/null 2>&1; then
          continue
        fi
        # Enter (or empty expect key) → attach
        exec "$TMUXBIN" attach -t "=$name"
        ;;
    esac
  done
}

# ---- main --------------------------------------------------------------------

main() {
  local repo="" fresh=0 list=0 pick="" startcmd="" claim=0 fill=0 wantpick=0 help=0 primary=0
  local client_version="" validate=0 validate_arg=""
  local dir sessions
  sessions=()

  while (( $# )); do
    case "$1" in
      --new)              fresh=1; shift ;;
      --list|-l)          list=1; shift ;;
      --resume|-R)        wantpick=1
                          if [[ -n "${2:-}" && "${2:-}" != -* ]]; then pick="$2"; shift 2; else shift; fi ;;
      --resume-closed)    claim=1; shift ;;
      --resume-or-new)    claim=1; fill=1; shift ;;
      --claude|-c)        startcmd="claude"; shift ;;
      --help|-h)          help=1; shift ;;
      --primary|-p)       primary=1; shift ;;
      --client-version)   client_version="${2:-}"; shift 2 ;;
      --validate)
        if [[ -z "${2:-}" || "${2:-}" == -* ]]; then
          echo "repo-session: --validate requires a <repo>" >&2
          exit 1
        fi
        validate=1
        validate_arg="$2"
        shift 2
        ;;
      --)                 shift; startcmd="$*"; break ;;
      -*)                 echo "repo-session: ignoring unknown flag '$1'" >&2; shift ;;
      *)                  if [[ -z "$repo" ]]; then repo="$1"; else startcmd="${startcmd:+$startcmd }$1"; fi; shift ;;
    esac
  done

  load_config
  parse_launchers

  # --validate dispatches first (before help/list/resume); never touches tmux.
  if (( validate )); then
    validate_repo "$validate_arg"
    exit $?
  fi

  # Version handshake (warn only; never block).
  if [[ -n "$client_version" ]]; then
    local ov
    ov="$(own_version | tr -d '[:space:]')"
    if [[ -n "$ov" && "$client_version" != "$ov" ]]; then
      echo "mossferry: client ${client_version} / remote ${ov} — run 'ferry update'" >&2
    fi
  fi

  if (( help )); then
    local ver S="" Z=""
    ver="$(own_version | tr -d '[:space:]')"
    ferry_banner
    if ui_tty 2>/dev/null && [[ ${GREEN_UI_MODE-none} != none ]]; then
      S="${UI_G-}${UI_BOLD-}"
      Z="${UI_Z-}"
    fi
    cat <<EOF
${S}Usage${Z}
  repo-session [repo] [flags]   remote brain for mossferry (picker default)

${S}Picker keys${Z}
  enter=attach · ctrl-x=kill · ctrl-r=rename · ctrl-a/ctrl-g=AI launchers
  list navigation wraps (cycle) · esc=quit
  (Launchers via FERRY_LAUNCHERS; defaults: ctrl-a:claude, ctrl-g:grok)

${S}Flags${Z}
  (none)             open the session picker (scoped to <repo> when given)
  --primary, -p      attach the repo's primary session, creating it if missing
  --new              force a fresh session  (repo, repo-2, repo-3, ...)
  --claude, -c       run \`claude\` in newly-created sessions  (default: neofetch)
  --list, -l         list sessions and exit  (with <repo>: just that repo;
                     without <repo>: every tmux session on the host)
  --resume [N|name]  no arg -> session picker; N -> the Nth session;
                     name -> attach that exact session (e.g. --resume syndcast-2)
  --resume-closed    reattach one EXISTING session per caller, distinct (atomic);
                     prefers detached, else takes over a stale-attached one. Across
                     a ghostty-grid each pane gets a different one; extras stay BLANK.
  --resume-or-new    like --resume-closed, but fill leftover panes with fresh
                     sessions (honouring --claude / -- cmd) -- so the grid fills.
  --client-version V version handshake (set by mossferry client)
  --validate <repo>  check repo exists under FERRY_REPO_BASE (no tmux; used by client)
  --help, -h         print this help and exit
  -- cmd...          custom startup command for newly-created sessions

${S}Config${Z}
  ~/.config/mossferry/config  (FERRY_* keys; env overrides file)
  FERRY_REPO_BASE, FERRY_DEFAULT_CMD, FERRY_LAUNCHERS, FERRY_BANNER, …

${S}Examples${Z}
  ferry manjaro-remote                            global session picker
  ferry manjaro-remote syndcast                   picker scoped to syndcast
  ferry manjaro-remote syndcast --primary         attach/create the primary session
  ferry manjaro-remote syndcast --new --claude    fresh session running claude
  ferry manjaro-remote syndcast --list            list syndcast's sessions
  ferry manjaro-remote --resume                   pick any session
  ghostty-grid -8 -- ferry manjaro-remote syndcast --resume-or-new --claude

mossferry ${ver} · the green ferry between your machines
EOF
    exit 0
  fi

  # --resume with N or name (bare --resume falls through to picker later)
  if (( wantpick )) && [[ -n "$pick" ]]; then
    if [[ "$pick" =~ ^[0-9]+$ ]]; then
      if [[ -n "$repo" ]]; then
        mapfile -t sessions < <("$TMUXBIN" list-sessions -F '#{session_name}' 2>/dev/null \
          | grep -E "^${repo}(-[0-9]+)?$" | sort -V)
      else
        mapfile -t sessions < <("$TMUXBIN" list-sessions -F '#{session_name}' 2>/dev/null | sort -V)
      fi
      local target="${sessions[$((pick-1))]:-}"
      if [[ -z "$target" ]]; then
        echo "no session #$pick${repo:+ for '$repo'}. available:" >&2
        local i=1 s
        for s in "${sessions[@]}"; do echo "  $i) $s" >&2; ((i++)) || true; done
        exit 1
      fi
      exec "$TMUXBIN" attach -t "$target"
    else
      if "$TMUXBIN" has-session -t "=$pick" 2>/dev/null; then
        exec "$TMUXBIN" attach -t "=$pick"
      fi
      echo "no session named '$pick'. available:" >&2
      "$TMUXBIN" list-sessions -F '#{session_name}' 2>/dev/null | sort -V | sed 's/^/  /' >&2
      exit 1
    fi
  fi

  # --list
  if (( list )); then
    if [[ -n "$repo" ]]; then
      mapfile -t sessions < <("$TMUXBIN" list-sessions -F '#{session_name}' 2>/dev/null \
        | grep -E "^${repo}(-[0-9]+)?$" | sort -V)
    else
      mapfile -t sessions < <("$TMUXBIN" list-sessions -F '#{session_name}' 2>/dev/null | sort -V)
    fi
    if (( ${#sessions[@]} == 0 )); then
      if [[ -n "$repo" ]]; then echo "no '$repo' sessions yet"; else echo "no tmux sessions running"; fi
      exit 0
    fi
    print_list
    exit 0
  fi

  # Typo guard: repo given but not a directory under base → error + list, never attach main.
  if [[ -n "$repo" ]]; then
    dir="${FERRY_REPO_BASE}/${repo}"
    if ! validate_repo "$repo"; then
      exit 1
    fi
  fi

  # --resume-closed / --resume-or-new: claim block (baseline, one blank-fallback change)
  if (( claim )); then
    if [[ -z "$repo" ]]; then
      echo "repo-session: --resume-closed/--resume-or-new require a <repo>" >&2
      exit 1
    fi
    _list_repo_sessions
    local lockf now ttl target s n c
    lockf="${TMPDIR:-/tmp}/repo-session-$repo.claim"
    exec 9>"$lockf"; flock 9
    now=$(date +%s); ttl=25; target=""
    claimable() {   # not reserved by another pane in the last ttl seconds
      local c; c=$("$TMUXBIN" show-options -t "$1" -v -q @claim_ts 2>/dev/null)
      [[ -z "$c" ]] || (( now - c >= ttl ))
    }
    # pass 1: prefer a genuinely DETACHED session
    for s in "${sessions[@]}"; do
      [[ "$("$TMUXBIN" display-message -p -t "$s" '#{session_attached}')" == "0" ]] || continue
      claimable "$s" || continue
      target="$s"; "$TMUXBIN" set-option -t "$s" @claim_ts "$now" >/dev/null 2>&1; break
    done
    # pass 2: none detached → TAKE OVER an attached one.
    if [[ -z "$target" ]]; then
      for s in "${sessions[@]}"; do
        claimable "$s" || continue
        target="$s"; "$TMUXBIN" set-option -t "$s" @claim_ts "$now" >/dev/null 2>&1; break
      done
    fi
    if [[ -z "$target" && $fill -eq 1 ]]; then
      n=2; target="$repo"
      while "$TMUXBIN" has-session -t "$target" 2>/dev/null; do target="$repo-$n"; ((n++)) || true; done
      "$TMUXBIN" new-session -d -s "$target" -c "$dir"
      "$TMUXBIN" send-keys -t "$target" "${startcmd:-$FERRY_DEFAULT_CMD}" C-m
      "$TMUXBIN" set-option -t "$target" @claim_ts "$now" >/dev/null 2>&1
    fi
    flock -u 9
    if [[ -n "$target" ]]; then exec "$TMUXBIN" attach -d -t "$target"; fi
    echo "no '$repo' sessions left to resume — blank shell" >&2
    # Blank fallback: plain login shell (no env -u SSH_CONNECTION; .bashrc auto-attach removed in Phase 2).
    exec "${SHELL:-/bin/bash}" -l
  fi

  # --primary: attach primary or create (baseline default, now explicit)
  if (( primary )); then
    if [[ -z "$repo" ]]; then
      echo "repo-session: --primary requires a <repo>" >&2
      exit 1
    fi
    local session="$repo"
    local lockf="${TMPDIR:-/tmp}/repo-session-$repo.claim"
    exec 9>"$lockf"; flock 9
    if ! "$TMUXBIN" has-session -t "$session" 2>/dev/null; then
      "$TMUXBIN" new-session -d -s "$session" -c "$dir"
      "$TMUXBIN" send-keys -t "$session" "${startcmd:-$FERRY_DEFAULT_CMD}" C-m
    fi
    flock -u 9
    exec "$TMUXBIN" attach -t "$session"
  fi

  # --new: force fresh session
  if (( fresh )); then
    if [[ -z "$repo" ]]; then
      echo "repo-session: --new requires a <repo>" >&2
      exit 1
    fi
    local session="$repo" n=2
    local lockf="${TMPDIR:-/tmp}/repo-session-$repo.claim"
    exec 9>"$lockf"; flock 9
    while "$TMUXBIN" has-session -t "$session" 2>/dev/null; do
      session="$repo-$n"
      ((n++)) || true
    done
    "$TMUXBIN" new-session -d -s "$session" -c "$dir"
    "$TMUXBIN" send-keys -t "$session" "${startcmd:-$FERRY_DEFAULT_CMD}" C-m
    flock -u 9
    exec "$TMUXBIN" attach -t "$session"
  fi

  # Default action / bare --resume: the picker.
  # Zero-session fast path when a repo is given and no live sessions exist.
  if [[ -n "$repo" ]]; then
    _list_repo_sessions
    if (( ${#sessions[@]} == 0 )); then
      echo "no live sessions for '${repo}' — created primary"
      local session="$repo"
      local lockf="${TMPDIR:-/tmp}/repo-session-$repo.claim"
      exec 9>"$lockf"; flock 9
      if ! "$TMUXBIN" has-session -t "$session" 2>/dev/null; then
        "$TMUXBIN" new-session -d -s "$session" -c "$dir"
        "$TMUXBIN" send-keys -t "$session" "${startcmd:-$FERRY_DEFAULT_CMD}" C-m
      fi
      flock -u 9
      exec "$TMUXBIN" attach -t "$session"
    fi
  fi

  run_picker
}

# LIB mode: define helpers only (for unit tests / sourcing).
if [[ "${REPO_SESSION_LIB:-}" == "1" ]]; then
  # When sourced: return to caller. When executed with LIB=1: exit quietly.
  return 0 2>/dev/null || exit 0
fi

main "$@"
